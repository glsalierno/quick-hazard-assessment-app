# Git LFS: track large DSSTox files in DSS/ for GitHub
# Install LFS once: https://git-lfs.com → then run: git lfs install
DSS/*.csv filter=lfs diff=lfs merge=lfs -text
DSS/*.xlsx filter=lfs diff=lfs merge=lfs -text
# Exception last so it wins: cas_dtxsid_mapping.csv in Git (not LFS) for Streamlit Cloud
DSS/cas_dtxsid_mapping.csv !filter !diff !merge
