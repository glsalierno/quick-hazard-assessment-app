# Copy this file to .env and edit paths for your machine.

# Optional OPERA path (preferred for local OPERA CLI integration)
HAZQUERY_OPERA_EXE=C:/app/opera/application/OPERA.exe
OPERA_INSTALL_DIR=C:/app/opera

# Optional local data paths (inside container defaults shown)
CHEMICAL_DB_PATH=C:/app/data/chemical_db.sqlite
P2OASYS_MATRIX_PATH=C:/app/data/Hazard Matrix Group Review 9-19-23.xlsx

# Optional offline IUCLID / REACH
# OFFLINE_LOCAL_ARCHIVE=C:/app/data/reach_study_results_dossiers_23-05-2023.zip
# IUCLID_FORMAT_DIR=C:/app/data/IUCLID6_6_format_9.0.0
DB_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/chemdb
COMPTOX_API_KEY=
# Same key family as COMPTOX_API_KEY (EPA CCTE / CompTox). Used by utils/validate.py for ToxVal API.
EPA_API_KEY=
# Optional: P2OASys-style CSV path for the Cross-Validate page “load CAS” button (must contain a CAS column).
# P2OASYS_COMPOUND_LIST_CSV=C:/path/to/P2OASys_Database_Results.csv

# ECHA via local QSAR Toolbox WebSuite (optional; bypasses ECHA WAF; start WebSuite first)
USE_QSAR_TOOLBOX=false
# Port from Toolbox Server / WebSuite: "Listening on localhost:####" (example: 8804 for Toolbox 4.7.1)
QSAR_TOOLBOX_PORT=8804
QSAR_HOST=127.0.0.1
QSAR_API_VERSION=v6
# auto = try https then http (Toolbox 4.7+ often serves TLS on the listening port)
QSAR_SCHEME=auto
# Local HTTPS is often self-signed; set true only if you use a proper CA-trusted cert
QSAR_VERIFY_SSL=false
QSAR_CACHE_DIR=data/qsar_cache
QSAR_PAGE_SIZE=100
QSAR_REQUEST_DELAY_MS=50
# Optional: path to CAS list (one per line) or CSV; else DSS/cas_dtxsid_mapping.csv is used if present
# QSAR_SUBSTANCE_SEED_PATH=
# QSAR_SEED_CAS_COLUMN=

# ECHA via IUCLID Public REST API (optional; replaces deprecated CSV URLs when enabled)
USE_IUCLID_API=false
# Documented IUCLID base path (recommended). For experimental /rest/v1 hosts set IUCLID_API_STYLE=rest.
IUCLID_API_BASE_URL=https://iuclid6.echa.europa.eu/iuclid6-ext/api/ext/v1/
IUCLID_API_STYLE=ext
IUCLID_PAGE_SIZE=100
IUCLID_CACHE_DIR=data/iuclid_cache
IUCLID_RAW_DIR=data/iuclid_raw
IUCLID_MAX_RETRIES=3
IUCLID_REQUEST_DELAY_MS=150
IUCLID_INVENTORY_CODE=EC
IUCLID_CLP_STRATEGY=by_ghs
IUCLID_HTTP_TIMEOUT_S=120
# Bypass Azure WAF JS challenges where possible (uses TLS/browser fingerprint; install cloudscraper).
IUCLID_USE_CLOUDSCRAPER=true
# If the host shows a disclaimer HTML interstitial, set these after inspecting browser DevTools:
# IUCLID_ACCEPT_POST_URL=
# IUCLID_ACCEPT_POST_BODY=

# Offline ECHA: REACH bulk (.7z → .i6z) + targeted ECHA CHEM scrape (no QSAR Toolbox)
USE_OFFLINE_ECHA=false
# Path to manually downloaded REACH Study Results .zip / .7z, or a folder of extracted .i6z files (skips REACH download)
# OFFLINE_LOCAL_ARCHIVE=C:\data\REACH_Study_Results_2023-06-12.zip
# Example (spaces in folder name — use quotes in PowerShell: $env:OFFLINE_LOCAL_ARCHIVE = "C:/.../ECHA IUCLID database/reach_study_results_dossiers_23-05-2023.zip")
# Optional: ECHA dossier-info XLSX (UUID → CAS/EC/name). If omitted, same folder as the archive is searched for *dossier_info*.xlsx
# OFFLINE_DOSSIER_INFO_XLSX=C:/.../reach_study_results-dossier_info_23-05-2023.xlsx
# OFFLINE_DOSSIER_INFO_SHEET=REACH Study Results 23-05-23
# Optional ECHA CHEM scrape only for substances missing GHS rows in Document.i6d (default off; SPA often empty)
OFFLINE_SCRAPE_CL=false
# Same WAF bypass pattern as IUCLID (recommended for iuclid6.echa.europa.eu)
OFFLINE_USE_CLOUDSCRAPER=true
OFFLINE_DATA_DIR=data/offline
OFFLINE_CACHE_DIR=data/offline_cache
# Comma-separated extra CSV URLs if the default registered_substances link 404s
# OFFLINE_REGISTERED_CSV_URLS=
# REACH_STUDY_RESULTS_URL=https://iuclid6.echa.europa.eu/download/.../REACH_Study_Results_YYYY-MM-DD.7z
REACH_STUDY_INDEX_URL=https://iuclid6.echa.europa.eu/reach-study-results
# DISCLAIMER_URL=
# DISCLAIMER_POST_DATA={"accept":"true"}
OFFLINE_CHEM_DELAY_S=1.5
OFFLINE_CHEM_MAX_WORKERS=5
# OFFLINE_MAX_CL=10
